{
  "name": "gemsprout",
  "version": "1.0.0",
  "description": "Family routines, photo proof, savings, and weekly growth across one home or two",
  "main": "index.js",
  "scripts": {
    "dev": "http-server . -a 0.0.0.0 -p 4173 -c-1",
    "test": "echo \"No default test configured. Use: npm run test:e2e\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:watch": "playwright test --grep \"@ui\" --headed --workers=1",
    "test:e2e:watch:slow": "playwright test --grep \"@ui\" --headed --workers=1 --project=chromium-slow"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/handofhate/GemSprout.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/handofhate/GemSprout/issues"
  },
  "homepage": "https://github.com/handofhate/GemSprout#readme",
  "devDependencies": {
    "@capacitor/assets": "^3.0.0",
    "@playwright/test": "^1.59.1",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.1.0",
    "@capacitor-firebase/messaging": "^8.1.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.0",
    "@capawesome/capacitor-badge": "^8.0.1",
    "@capgo/capacitor-native-biometric": "^8.0.0",
    "@revenuecat/purchases-capacitor": "^12.3.0"
  }
}
