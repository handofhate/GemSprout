{
  "name": "gemsprout",
  "version": "1.0.0",
  "description": "Family routines, photo proof, savings, and weekly growth across one home or two",
  "main": "index.js",
  "scripts": {
    "dev": "http-server . -a 0.0.0.0 -p 4173 -c-1",
    "dev:v2": "vite --config v2/vite.config.ts --host 127.0.0.1 --port 4273",
    "build:v2:app": "vite build --config v2/vite.config.ts",
    "test": "echo \"No default test configured. Use: npm run test:e2e\"",
    "build:v2": "tsc -p v2/tsconfig.json",
    "typecheck:v2": "tsc -p v2/tsconfig.json --noEmit",
    "migration:v2:preview": "npm run build:v2 && node v2/scripts/preview-v1-migration.cjs 6.10backup.json migration-preview",
    "migration:v2:import:dry": "npm run build:v2 && node v2/scripts/import-v1-migration.cjs --input 6.10backup.json --family-id migration-preview --project gemsprout-v2-dev --database \"(default)\"",
    "migration:v2:import:write:dev": "npm run build:v2 && node v2/scripts/import-v1-migration.cjs --input 6.10backup.json --family-id migration-preview --project gemsprout-v2-dev --database \"(default)\" --write",
    "seed:v2:test-data:dry": "node v2/scripts/seed-v2-test-data.cjs",
    "seed:v2:test-data:dev": "node v2/scripts/seed-v2-test-data.cjs --write",
    "rules:v2:deploy:dev": "firebase deploy --config v2/firebase.dev.json --only firestore:rules --project gemsprout-v2-dev",
    "test:v2": "npm run build:v2 && node --test \"v2/dist/tests/**/*.test.js\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:watch": "playwright test --grep \"@ui\" --headed --workers=1",
    "test:e2e:watch:slow": "playwright test --grep \"@ui\" --headed --workers=1 --project=chromium-slow"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/handofhate/GemSprout.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/handofhate/GemSprout/issues"
  },
  "homepage": "https://github.com/handofhate/GemSprout#readme",
  "devDependencies": {
    "@capacitor/assets": "^3.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^26.1.1",
    "firebase-admin": "^14.1.0",
    "http-server": "^14.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.1.0",
    "@capacitor-firebase/messaging": "^8.1.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.0",
    "@capawesome/capacitor-badge": "^8.0.1",
    "@capgo/capacitor-native-biometric": "^8.0.0",
    "@revenuecat/purchases-capacitor": "^12.3.0",
    "firebase": "^12.15.0"
  }
}
