{
  "appId": "com.gemsprout.ios",
  "appName": "GemSprout",
  "webDir": "www",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "FirebaseAuthentication": {
      "skipNativeAuth": true,
      "providers": ["google.com", "apple.com"]
    }
  },
  "ios": {
    "scheme": "GemSprout",
    "contentInset": "never",
    "infoPlist": {
      "ITSAppUsesNonExemptEncryption": false,
      "NSCameraUsageDescription": "GemSprout uses your camera so kids can take before and after photos of completed chores."
    }
  }
}
